{
  "mcpServers": {
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ],
      "env": {}
    },
    "github": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    },
    "figma": {
      "type": "stdio",
      "command": "/opt/homebrew/bin/python3",
      "args": [
        "/Users/yongqian/Desktop/AICAP/scripts/mcp-idle-wrapper.py",
        "npx",
        "-y",
        "@figma/mcp"
      ],
      "env": {
        "MCP_IDLE_TIMEOUT": "1800",
        "FIGMA_API_KEY": "${FIGMA_API_KEY}"
      }
    },
    "penpot": {
      "type": "stdio",
      "command": "/opt/homebrew/bin/python3",
      "args": [
        "/Users/yongqian/Desktop/AICAP/scripts/mcp-idle-wrapper.py",
        "npx",
        "-y",
        "@penpot/mcp"
      ],
      "env": {
        "MCP_IDLE_TIMEOUT": "1800",
        "PENPOT_API_TOKEN": "${PENPOT_API_TOKEN}"
      }
    }
  }
}
